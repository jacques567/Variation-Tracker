# Supabase
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Stripe
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PRICE_ID=

# App
NEXT_PUBLIC_APP_URL=https://vartracker.com

# Security — generate with: openssl rand -hex 16
CSRF_SECRET=

# Email (Resend) — used for signature confirmations and variation expiry notifications
RESEND_API_KEY=

# Vercel Cron — generate with: openssl rand -hex 16
# Authorizes /api/cron/* routes; Vercel sends this automatically as a Bearer token
# for scheduled invocations (https://vercel.com/docs/cron-jobs/manage-cron-jobs#securing-cron-jobs)
CRON_SECRET=

# Address lookup (Ideal Postcodes) — off by default, replaces postcodes.io (district-only)
# with full premise-level address autocomplete. Flip NEXT_PUBLIC_USE_IDEAL_POSTCODES to
# "true" once IDEAL_POSTCODES_API_KEY is set (paid — no permanent free tier).
NEXT_PUBLIC_USE_IDEAL_POSTCODES=false
IDEAL_POSTCODES_API_KEY=
