# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*
!.env.example

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

# Claude Code worktrees
.claude/worktrees/

# Local task tracking (not synced to repo)
TASKS.md

# Test results and snapshots
test-results/
tests/e2e/visual-regression.spec.ts-snapshots/

# Pipeline handoff files (ephemeral, cleared after each PR)
.pipeline/

# Stage-specific folders (local workspace only, not synced to repo)
building/
research/
planning/
testing/
design/
delivery/
